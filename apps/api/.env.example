# Runtime-mal for norsk tale inn -> samisk audio ut.
# Denne malen er trygg a committe. Bytt ut alle absolute stier med lokale verdier.

# Slatt av stub-modus for ekte ASR, oversetting og TTS.
HSJS_PROVIDER_STUB_MODE=false
HSJS_PROVIDER_RUNTIME=transformers
HSJS_HF_DEVICE=auto
HSJS_HF_DTYPE=float16

# Offentlig Divvun TTS-API. Dette er ny default og dekker alle stemmene som er publisert for sme, smj og sma.
HSJS_TTS_RUNTIME=divvun-api
HSJS_TTS_API_BASE_URL=https://api-giellalt.uit.no/tts

# Tilgjengelige stemmer akkurat na:
# - sme: biret, mahtte, sunna
# - smj: abmut, nihkol, sigga
# - sma: aanna

# Alternativ: lokal Divvun speech-runtime for .pte-modeller.
# Hjelper for a finne voice/vocoder lokalt og skrive en .env-snutt:
# python -m app.scripts.setup_divvun_tts --variant sme --search-root ~/Downloads --write-env .env
# Etter `pip install -e .` kan du ogsa bruke `hsjs-setup-divvun-tts` direkte.
# HSJS_TTS_RUNTIME=divvun-command
# HSJS_TTS_COMMAND=/absolute/path/to/divvun-speech-synthesize

# Sett bare denne hvis lokal kommando ma kjores fra et checkout.
# HSJS_TTS_COMMAND_CWD=/absolute/path/to/divvun-speech-rs

# Lokal SME voice/vocoder for divvun-command brukes bare hvis du aktiverer lokal runtime.
# HSJS_TTS_SME_VOICE_MODEL=/absolute/path/to/sme/voice.pte
# HSJS_TTS_SME_VOCODER_MODEL=/absolute/path/to/sme/vocoder.pte
# HSJS_TTS_SME_SPEAKER_ID=1
# HSJS_TTS_SME_LANGUAGE_ID=1
# HSJS_TTS_SME_PACE=1.0

# Lokal lulesamisk kan aktiveres analogt ved behov.
# HSJS_TTS_SMJ_VOICE_MODEL=/absolute/path/to/smj/voice.pte
# HSJS_TTS_SMJ_VOCODER_MODEL=/absolute/path/to/smj/vocoder.pte
# HSJS_TTS_SMJ_SPEAKER_ID=1
# HSJS_TTS_SMJ_LANGUAGE_ID=1
# HSJS_TTS_SMJ_PACE=1.0

# Lokal sorsamisk kan aktiveres analogt ved behov.
# HSJS_TTS_SMA_VOICE_MODEL=/absolute/path/to/sma/voice.pte
# HSJS_TTS_SMA_VOCODER_MODEL=/absolute/path/to/sma/vocoder.pte
# HSJS_TTS_SMA_SPEAKER_ID=1
# HSJS_TTS_SMA_LANGUAGE_ID=1
# HSJS_TTS_SMA_PACE=1.0